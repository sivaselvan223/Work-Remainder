# MongoDB Connection String - Required for Railway deployment
# On Railway, this is auto-generated from the MongoDB service reference
MONGODB_URI=mongodb://username:password@host:port/database

# JWT Secret for authentication - Required for production
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Server Port - Optional, defaults to 8080
PORT=8080

# CORS Origins - Optional, defaults to localhost:5173 and localhost:3000
# For production, specify your frontend URL
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://work-remainder.vercel.app

# Email Service Configuration - Optional
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_password
# SENDER_EMAIL=noreply@example.com

